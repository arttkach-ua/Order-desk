<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="alter products image_url to text" author="artem.tkach" dbms="postgresql">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="products" columnName="image_url"/>
        </preConditions>
        <sql>
            ALTER TABLE products
            ALTER COLUMN image_url TYPE text USING image_url::text;
        </sql>
    </changeSet>

    <changeSet id="alter product_categories image_url to text" author="artem.tkach" dbms="postgresql">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="product_categories" columnName="image_url"/>
        </preConditions>
        <sql>
            ALTER TABLE product_categories
            ALTER COLUMN image_url TYPE text USING image_url::text;
        </sql>
    </changeSet>

    <changeSet id="create table price_types" author="artem.tkach" dbms="postgresql">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="price_types"/>
            </not>
        </preConditions>
        <createTable tableName="price_types">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name = "is_default" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="unique-default-price-type" author="artem.tkach" dbms="postgresql">
        <createIndex indexName="ux_price_types_default_true"
                     tableName="price_types"
                     unique="true">
            <column name="is_default"/>
            <where>is_default = true</where>
        </createIndex>
    </changeSet>

    <changeSet id="insert-default-price-type" author="artem.tkach" dbms="postgresql">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM price_types WHERE is_default = true
            </sqlCheck>
        </preConditions>
        <insert tableName="price_types">
            <column name="name" value="Retail"/>
            <column name="is_default" valueBoolean="true"/>
        </insert>
    </changeSet>

    <changeSet id="create table client_price_type_connection" author="artem.tkach" dbms="postgresql">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="client_price_type_connection"/>
            </not>
        </preConditions>
        <createTable tableName="client_price_type_connection">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="client_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_client_price_type_connection_client"
                             referencedTableName="customers"
                             referencedColumnNames="id"/>
            </column>
            <column name="price_type_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_client_price_type_connection_price_type"
                             referencedTableName="price_types"
                             referencedColumnNames="id"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="unique-client-price-type-connection" author="artem.tkach" dbms="postgresql">
        <createIndex indexName="ux_client_price_type_connection_unique"
                     tableName="client_price_type_connection"
                     unique="true">
            <column name="client_id"/>
            <column name="price_type_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>


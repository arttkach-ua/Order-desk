<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- Console appender with JSON format for Loki -->
    <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeContext>false</includeContext>
            <fieldNames>
                <timestamp>timestamp</timestamp>
                <version>[ignore]</version>
                <message>message</message>
                <logger>logger</logger>
                <thread>thread</thread>
                <level>level</level>
                <levelValue>[ignore]</levelValue>
                <stackTrace>stacktrace</stackTrace>
            </fieldNames>
            <customFields>{"application":"orders-desk","environment":"${SPRING_PROFILES_ACTIVE:-production}"}</customFields>
        </encoder>
    </appender>

    <!-- Console appender with colored pattern for local development -->
    <appender name="CONSOLE_PATTERN" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %clr([%thread]){faint} %clr(%-5level) %clr(%logger{36}){cyan} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Use JSON in production, pattern in local development -->
    <springProfile name="production,kubernetes,k8s">
        <root level="INFO">
            <appender-ref ref="CONSOLE_JSON"/>
        </root>
        <logger name="com.ta.orders" level="DEBUG"/>
    </springProfile>

    <springProfile name="default,dev,local">
        <root level="INFO">
            <appender-ref ref="CONSOLE_PATTERN"/>
        </root>
        <logger name="com.ta.orders" level="DEBUG"/>
    </springProfile>
</configuration>

